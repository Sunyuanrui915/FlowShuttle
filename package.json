{
  "name": "flowshuttle",
  "version": "0.2.1",
  "description": "Local-first personal work progress journal",
  "main": "out/main/index.js",
  "author": "Flow Shuttle",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck && electron-vite build",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist": "npm run dist:win",
    "create:test-data": "electron scripts/create-test-data.cjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/markdown": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "better-sqlite3": "^12.9.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "app.flowshuttle",
    "productName": "Flow Shuttle",
    "artifactName": "FlowShuttle-${version}-setup.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "assets/icons/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icons/flow-shuttle-icon.ico",
        "to": "assets/icons/flow-shuttle-icon.ico"
      }
    ],
    "icon": "build/icon.ico",
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "include": "scripts/installer-shortcuts.nsh",
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Flow Shuttle",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Sunyuanrui915",
        "repo": "FlowShuttle",
        "releaseType": "release"
      }
    ]
  }
}
